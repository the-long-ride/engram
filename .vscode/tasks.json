{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Docusaurus Dev Server",
      "type": "shell",
      "command": "pnpm start",
      "options": {
        "cwd": "${workspaceFolder}/website"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "docusaurus",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Docusaurus",
          "endsPattern": "compiled successfully|Local:|localhost"
        }
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Build Docusaurus (Fast, EN only)",
      "type": "shell",
      "command": "pnpm build:fast",
      "options": {
        "cwd": "${workspaceFolder}/website"
      },
      "problemMatcher": []
    }
  ]
}
