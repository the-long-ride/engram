{
  "name": "@the-long-ride/engram",
  "version": "0.0.24",
  "description": "Portable, human-approved memory for AI agents. Grow with you & your teams.",
  "keywords": [
    "cli",
    "ai",
    "mcp",
    "opencode",
    "openai",
    "memory-management",
    "cursor",
    "knowledge-base",
    "codex",
    "claude",
    "local-first",
    "agent-framework",
    "ai-agent",
    "mcp-server",
    "agent-memory"
  ],
  "type": "module",
  "private": false,
  "license": "GPL-3.0-only",
  "author": "the-long-ride",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/the-long-ride/engram.git"
  },
  "bugs": {
    "url": "https://github.com/the-long-ride/engram/issues"
  },
  "homepage": "https://github.com/the-long-ride/engram#readme",
  "bin": {
    "engram": "./dist/bin/engram.js",
    "engram-mcp": "./dist/bin/engram-mcp.js"
  },
  "files": [
    "dist",
    "docs",
    "prompts",
    "templates",
    "README.md",
    "llm.txt",
    "GUIDELINE.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "generate:version": "node scripts/generate-version.mjs",
    "build": "npm run generate:version && tsc && node scripts/build-web.mjs && node scripts/copy-assets.mjs",
    "typecheck": "npm run generate:version && tsc --noEmit",
    "test": "npm run build && node scripts/run-tests.mjs",
    "test:core": "npm run build && node --test tests/core.test.mjs tests/safety.test.mjs",
    "test:cli": "npm run build && node --test tests/cli/*.test.mjs",
    "test:mcp": "npm run build && node --test tests/mcp.test.mjs",
    "test:package": "npm run build && node --test tests/publish/*.test.mjs",
    "test:app": "jest --config jest.config.cjs",
    "coverage": "npm run generate:version && tsc --sourceMap false && node --experimental-test-coverage --test tests/core.test.mjs tests/safety.test.mjs tests/conflict.test.mjs tests/init-migration.test.mjs tests/mcp.test.mjs tests/skillset.test.mjs tests/tamper.test.mjs tests/web-api.test.mjs tests/publish/*.test.mjs tests/cli/*.test.mjs",
    "debug:cli": "npm run build && node --inspect-brk dist/bin/engram.js",
    "lint:lines": "node scripts/check-lines.mjs && node scripts/check-web-assets.mjs",
    "pack:dry-run": "npm pack --dry-run --ignore-scripts",
    "publish": "npm publish --access public --ignore-scripts",
    "prepublishOnly": "npm run test:package",
    "prepack": "npm run typecheck && npm test && npm run lint:lines"
  },
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {
    "@the-long-ride/markdown-them": "1.3.1",
    "better-sqlite3": "12.10.0",
    "sqlite-vec": "0.1.9"
  },
  "peerDependenciesMeta": {
    "@the-long-ride/markdown-them": {
      "optional": true
    },
    "better-sqlite3": {
      "optional": true
    },
    "sqlite-vec": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.28.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "ts-jest": "^29.4.11",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
