{
  "name": "@the-long-ride/engram",
  "version": "0.0.3",
  "description": "Portable, human-approved memory for AI agents. Grow with you & your teams.",
  "keywords": [
    "cli",
    "ai",
    "mcp",
    "opencode",
    "openai",
    "memory-management",
    "cursor",
    "knowledge-base",
    "codex",
    "claude",
    "local-first",
    "agent-framework",
    "ai-agent",
    "mcp-server",
    "agent-memory"
  ],
  "type": "module",
  "private": false,
  "license": "GPL-3.0-only",
  "author": "the-long-ride",
  "bin": {
    "engram": "./dist/bin/engram.js",
    "engram-mcp": "./dist/bin/engram-mcp.js"
  },
  "files": [
    "dist",
    "docs",
    "prompts",
    "templates",
    "README.md",
    "GUIDELINE.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "npm run build && node --test tests/*.test.mjs",
    "test:core": "npm run build && node --test tests/core.test.mjs tests/safety.test.mjs",
    "test:cli": "npm run build && node --test tests/cli.test.mjs",
    "test:mcp": "npm run build && node --test tests/mcp.test.mjs",
    "coverage": "tsc --sourceMap false && node --experimental-test-coverage --test tests/*.test.mjs",
    "debug:cli": "npm run build && node --inspect-brk dist/bin/engram.js",
    "lint:lines": "node scripts/check-lines.mjs",
    "pack:dry-run": "npm pack --dry-run --ignore-scripts",
    "prepack": "npm run typecheck && npm test && npm run lint:lines"
  },
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {
    "@the-long-ride/markdown-them": "*",
    "better-sqlite3": "*",
    "sqlite-vec": "*"
  },
  "peerDependenciesMeta": {
    "@the-long-ride/markdown-them": {
      "optional": true
    },
    "better-sqlite3": {
      "optional": true
    },
    "sqlite-vec": {
      "optional": true
    }
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
